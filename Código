#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int opcao;

    srand(time(NULL));

    while (1) {
        system("cls");

        printf("===== MENU PRINCIPAL =====\n");
        printf("1. Perguntas e Respostas\n");
        printf("2. Cobra na Caixa\n");
        printf("3. Gousmas War\n");
        printf("0. Sair\n");
        printf("==========================\n");
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);

        if (opcao == 1) {
            int resposta, acertos = 0;

            system("cls");

            printf("=== PERGUNTA 1 ===\n");
            printf("Qual a capital do Brasil?\n");
            printf("1) Rio de Janeiro\n2) Sao Paulo\n3) Brasilia\n4) Salvador\n");
            scanf("%d", &resposta);
            if (resposta == 3) { printf("Correto!\n"); acertos++; }
            else { printf("Errado! Resposta correta: Brasilia\n"); }
            system("pause");

            system("cls");
            printf("=== PERGUNTA 2 ===\n");
            printf("Quanto e 2 + 2?\n");
            printf("1) 3\n2) 4\n3) 5\n4) 6\n");
            scanf("%d", &resposta);
            if (resposta == 2) { printf("Correto!\n"); acertos++; }
            else { printf("Errado! Resposta correta: 4\n"); }
            system("pause");

            system("cls");
            printf("=== PERGUNTA 3 ===\n");
            printf("Qual planeta e conhecido como planeta vermelho?\n");
            printf("1) Terra\n2) Marte\n3) Jupiter\n4) Venus\n");
            scanf("%d", &resposta);
            if (resposta == 2) { printf("Correto!\n"); acertos++; }
            else { printf("Errado! Resposta correta: Marte\n"); }
            system("pause");

            system("cls");
            printf("=== PERGUNTA 4 ===\n");
            printf("Qual linguagem estamos usando?\n");
            printf("1) Python\n2) Java\n3) C\n4) PHP\n");
            scanf("%d", &resposta);
            if (resposta == 3) { printf("Correto!\n"); acertos++; }
            else { printf("Errado! Resposta correta: C\n"); }
            system("pause");

            system("cls");
            printf("=== PERGUNTA 5 ===\n");
            printf("Quantos dias tem uma semana?\n");
            printf("1) 5\n2) 6\n3) 7\n4) 8\n");
            scanf("%d", &resposta);
            if (resposta == 3) { printf("Correto!\n"); acertos++; }
            else { printf("Errado! Resposta correta: 7\n"); }
            system("pause");

            system("cls");
            printf("Voce acertou %d de 5 perguntas!\n", acertos);
            system("pause");
        }

        if (opcao == 2) {
            int jogar = 1;

            while (jogar == 1) {
                int caixaBotao = rand() % 5 + 1;
                int caixaCobra;
                int i;

                do {
                    caixaCobra = rand() % 5 + 1;
                } while (caixaCobra == caixaBotao);

                char nomes[7][20] = {
                    "Ramses", "Cleopatra", "Anubis",
                    "Horus", "Osiris", "Isis", "Tutankhamon"
                };

                int escolha1, escolha2;

                system("cls");
                printf("Escolha o nome do Jogador 1:\n");
                for (i = 0; i < 7; i++) {
                    printf("%d - %s\n", i + 1, nomes[i]);
                }
                scanf("%d", &escolha1);

                system("cls");
                printf("Escolha o nome do Jogador 2:\n");
                for (i = 0; i < 7; i++) {
                    printf("%d - %s\n", i + 1, nomes[i]);
                }
                scanf("%d", &escolha2);

                char *jogador1 = nomes[escolha1 - 1];
                char *jogador2 = nomes[escolha2 - 1];

                int turno = rand() % 2;
                int caixa;
                int fim = 0;

                while (!fim) {
                    system("cls");

                    if (turno == 0) printf("Vez de %s\n", jogador1);
                    else printf("Vez de %s\n", jogador2);

                    printf("Escolha uma caixa (1 a 5): ");
                    scanf("%d", &caixa);

                    if (caixa == caixaCobra) {
                        printf("A COBRA! Fim de jogo!\n");
                        if (turno == 0) printf("%s perdeu!\n", jogador1);
                        else printf("%s perdeu!\n", jogador2);
                        fim = 1;
                    } 
                    else if (caixa == caixaBotao) {
                        printf("VOCE ACHOU O BOTAO! Venceu!\n");
                        if (turno == 0) printf("%s venceu!\n", jogador1);
                        else printf("%s venceu!\n", jogador2);
                        fim = 1;
                    } 
                    else {
                        printf("Caixa vazia...\n");
                        system("pause");
                        turno = 1 - turno;
                    }
                }

                system("pause");

                printf("\n1 - Jogar novamente\n");
                printf("0 - Voltar ao menu\n");
                scanf("%d", &jogar);
            }
        }

        if (opcao == 3) {
            int jogar = 1;

            while (jogar == 1) {
                int g1[2] = {1, 1};
                int g2[2] = {1, 1};
                int vivos1 = 2, vivos2 = 2;
                int turno = rand() % 2;

                while (vivos1 > 0 && vivos2 > 0) {
                    int i;

                    system("cls");

                    printf("=== GOUSMAS WAR ===\n\n");

                    printf("Jogador 1:\n");
                    for (i = 0; i < 2; i++)
                        if (g1[i] > 0)
                            printf("Gousma %d - Furia: %d\n", i + 1, g1[i]);

                    printf("\nJogador 2:\n");
                    for (i = 0; i < 2; i++)
                        if (g2[i] > 0)
                            printf("Gousma %d - Furia: %d\n", i + 1, g2[i]);

                    if (turno == 0) printf("\nVez do Jogador 1\n");
                    else printf("\nVez do Jogador 2\n");

                    int acao;
                    printf("1 - Atacar\n2 - Dividir\nEscolha: ");
                    scanf("%d", &acao);

                    if (acao == 1) {
                        int atk, alvo;

                        printf("Sua Gousma (1 ou 2): ");
                        scanf("%d", &atk);
                        printf("Alvo inimigo (1 ou 2): ");
                        scanf("%d", &alvo);

                        atk--; alvo--;

                        if (turno == 0 && g1[atk] > 0 && g2[alvo] > 0) {
                            g2[alvo] += g1[atk];
                            if (g2[alvo] > 5) { g2[alvo] = 0; vivos2--; printf("Inimiga morreu!\n"); }
                        }

                        if (turno == 1 && g2[atk] > 0 && g1[alvo] > 0) {
                            g1[alvo] += g2[atk];
                            if (g1[alvo] > 5) { g1[alvo] = 0; vivos1--; printf("Inimiga morreu!\n"); }
                        }

                        system("pause");
                    }

                    if (acao == 2) {
                        int origem, destino;

                        printf("Dividir qual Gousma (1 ou 2): ");
                        scanf("%d", &origem);
                        origem--;

                        if (turno == 0 && g1[origem] > 1) {
                            destino = (g1[0]==0)?0:(g1[1]==0?1:-1);
                            if (destino != -1) { g1[origem]--; g1[destino]=1; vivos1++; }
                        }

                        if (turno == 1 && g2[origem] > 1) {
                            destino = (g2[0]==0)?0:(g2[1]==0?1:-1);
                            if (destino != -1) { g2[origem]--; g2[destino]=1; vivos2++; }
                        }

                        system("pause");
                    }

                    turno = 1 - turno;
                }

                system("cls");

                if (vivos1 == 0) printf("Jogador 2 venceu!\n");
                else printf("Jogador 1 venceu!\n");

                system("pause");

                printf("\n1 - Jogar novamente\n");
                printf("0 - Voltar ao menu\n");
                scanf("%d", &jogar);
            }
        }

        if (opcao == 0) {
            system("cls");
            printf("Saindo do programa...\n");
            break;
        }

        if (opcao < 0 || opcao > 3) {
            printf("Opcao invalida!\n");
            system("pause");
        }
    }

    return 0;
}
